# Tüm dosyalar için LF satır sonu (önce genel kural)
* text=auto eol=lf

# Unity kaynak dosyaları - text olarak işle
*.cs text eol=lf
*.shader text eol=lf
*.hlsl text eol=lf
*.cginc text eol=lf
*.glsl text eol=lf
*.compute text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.inputactions text eol=lf

# Unity Meta dosyaları - text kalır (LFS değil)
*.meta -filter -diff -merge text

# Görseller - Git LFS
*.png filter=lfs diff=lfs merge=lfs -text
